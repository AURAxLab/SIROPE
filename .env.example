# ============================================================
# SIROPE — Variables de Entorno (ejemplo)
# Copiar como .env y ajustar los valores
# ============================================================

# Base de datos
# Desarrollo (SQLite): file:./data/dev.db
# Producción (PostgreSQL): postgresql://user:password@host:5432/sirope
DATABASE_URL="file:./data/dev.db"

# NextAuth
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="CAMBIAR-ESTE-SECRETO-EN-PRODUCCION"
NEXTAUTH_URL="http://localhost:3000"

# Email (producción)
# SMTP_HOST="smtp.ejemplo.com"
# SMTP_PORT="587"
# SMTP_USER="noreply@ejemplo.com"
# SMTP_PASSWORD="password"
# SMTP_FROM="SIROPE <noreply@ejemplo.com>"

# LDAP (opcional)
# La configuración LDAP se maneja desde la UI de admin:
# Administración → Configuración → Autenticación → LDAP
# No requiere variables de entorno — se almacena en la BD.
# Para habilitar, instale: npm install ldapts
